# MongoDB (optional for crawl; required for seed-tools / weekly sync)
MONGODB_URI=mongodb://localhost:27017
# Optional when URI has no default database name:
MONGODB_DB=lawagents

# OpenAI (optional for crawl-datarade-legal-apis.py — static lists used if unset)
OPENAI_API_KEY=sk-...

